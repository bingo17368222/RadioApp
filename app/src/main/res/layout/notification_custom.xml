<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC1a1a2e">

    <!-- 标题区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_notification"
            android:scaleType="centerInside" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/notification_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Radio App"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/notification_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在播放"
                android:textSize="12sp"
                android:textColor="#CCCCCC"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- 回放进度条区域（仅回放时显示，20个跳转点：0%,5%,10%...95%,100%） -->
    <LinearLayout
        android:id="@+id/notification_progress_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/notification_time_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00/00:00"
            android:textSize="10sp"
            android:textColor="#CCCCCC"
            android:maxLines="1" />

        <!-- 进度条框架：32dp高度防误触，20个5%精度点击区域 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="2dp">

            <ProgressBar
                android:id="@+id/notification_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:max="1000"
                android:progress="0"
                android:progressDrawable="@drawable/notification_progress_drawable" />

            <!-- 20个跳转点：0%, 5%, 10%, 15%... 95%, 100% -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal">

                <LinearLayout android:id="@+id/btn_seek_0"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_5"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_10" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_15" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_20" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_25" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_30" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_35" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_40" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_45" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_50" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_55" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_60" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_65" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_70" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_75" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_80" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_85" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_90" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_95" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_100" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- 7个按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:paddingTop="2dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/btn_rewind"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#884488CC"
            android:padding="2dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/notif_rewind"
                android:scaleType="centerInside" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-15s"
                android:textSize="8sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_prev_segment"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#8833AA55"
            android:padding="2dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/notif_skip"
                android:scaleType="centerInside" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="上片段"
                android:textSize="8sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_prev_episode"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#88DD8833"
            android:padding="2dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/notif_prev"
                android:scaleType="centerInside" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="上节目"
                android:textSize="8sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_play_pause"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#AAFF5533"
            android:padding="2dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:id="@+id/play_pause_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/notif_play"
                android:scaleType="centerInside" />
            <TextView
                android:id="@+id/play_pause_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="播放"
                android:textSize="8sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_next_episode"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#88DD8833"
            android:padding="2dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/notif_next"
                android:scaleType="centerInside" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="下节目"
                android:textSize="8sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_next_segment"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#8833AA55"
            android:padding="2dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/notif_skip"
                android:scaleType="centerInside" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="下片段"
                android:textSize="8sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_forward"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#884488CC"
            android:padding="2dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/notif_forward"
                android:scaleType="centerInside" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+15s"
                android:textSize="8sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>