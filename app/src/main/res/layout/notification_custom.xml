<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC1a1a2e"
    android:minHeight="64dp">

    <!-- 标题区域（紧凑） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_notification"
            android:scaleType="centerInside" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginStart="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/notification_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Radio App"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/notification_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在播放"
                android:textSize="11sp"
                android:textColor="#CCCCCC"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 回放进度条区域（紧凑） -->
    <LinearLayout
        android:id="@+id/notification_progress_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="1dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/notification_time_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00/00:00"
            android:textSize="9sp"
            android:textColor="#CCCCCC"
            android:maxLines="1" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginTop="1dp">

            <ProgressBar
                android:id="@+id/notification_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:max="1000"
                android:progress="0"
                android:progressDrawable="@drawable/notification_progress_drawable" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:orientation="horizontal">

                <LinearLayout android:id="@+id/btn_seek_0"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_2"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_4"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_6"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_8"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_10" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_12" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_14" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_16" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_18" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_20" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_22" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_24" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_26" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_28" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_30" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_32" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_34" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_36" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_38" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_40" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_42" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_44" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_46" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_48" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_50" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_52" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_54" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_56" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_58" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_60" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_62" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_64" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_66" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_68" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_70" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_72" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_74" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_76" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_78" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_80" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_82" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_84" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_86" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_88" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_90" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_92" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_94" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_96" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_98" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:id="@+id/btn_seek_100" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- 7个按钮（紧凑布局，减小高度防止被系统隐藏） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:minHeight="36dp">

        <LinearLayout
            android:id="@+id/btn_rewind"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#884488CC"
            android:padding="1dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/notif_rewind"
                android:scaleType="centerInside" />
            <TextView
                android:id="@+id/rewind_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-15s"
                android:textSize="7sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_prev_segment"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#8833AA55"
            android:padding="1dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/notif_skip"
                android:scaleType="centerInside" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="上片段"
                android:textSize="7sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_prev_episode"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#88DD8833"
            android:padding="1dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/notif_prev"
                android:scaleType="centerInside" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="上节目"
                android:textSize="7sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_play_pause"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#AAFF5533"
            android:padding="1dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:id="@+id/play_pause_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/notif_play"
                android:scaleType="centerInside" />
            <TextView
                android:id="@+id/play_pause_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="播放"
                android:textSize="7sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_next_episode"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#88DD8833"
            android:padding="1dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/notif_next"
                android:scaleType="centerInside" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="下节目"
                android:textSize="7sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_next_segment"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#8833AA55"
            android:padding="1dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/notif_skip"
                android:scaleType="centerInside" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="下片段"
                android:textSize="7sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_forward"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#884488CC"
            android:padding="1dp"
            android:layout_marginStart="1dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/notif_forward"
                android:scaleType="centerInside" />
            <TextView
                android:id="@+id/forward_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+15s"
                android:textSize="7sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>