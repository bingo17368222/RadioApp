<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <TextView
        android:id="@+id/tv_time"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:textColor="?attr/appTextMuted"
        android:textSize="13sp"
        android:gravity="center" />

    <View
        android:layout_width="1dp"
        android:layout_height="32dp"
        android:background="?attr/appDivider"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/appTextPrimary"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_dislike_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👎 不喜欢"
                android:textSize="11sp"
                android:textColor="#E74C3C"
                android:visibility="gone"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/tv_cached_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已缓存"
                android:textSize="11sp"
                android:textColor="#4CAF50"
                android:visibility="gone"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_play"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_play"
        android:scaleType="centerInside"
        android:layout_marginStart="8dp" />
</LinearLayout>
