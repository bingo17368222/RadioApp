<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackground">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 播放设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="播放设置"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI模型"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <Spinner
                android:id="@+id/spinner_ai_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASR方案"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <Spinner
                android:id="@+id/spinner_asr_provider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="自动跳过水分"
                    android:textColor="?attr/appTextPrimary"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/switch_auto_skip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="连续播放"
                    android:textColor="?attr/appTextPrimary"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/switch_continuous_play"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="自动下载缓存"
                    android:textColor="?attr/appTextPrimary"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/switch_auto_download"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="启用预缓存"
                    android:textColor="?attr/appTextPrimary"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/switch_auto_cache"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="启用音频焦点"
                    android:textColor="?attr/appTextPrimary"
                    android:textSize="14sp" />
                <Switch
                    android:id="@+id/switch_audio_focus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- 界面设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="界面设置"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="界面风格"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <Spinner
                android:id="@+id/spinner_theme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:id="@+id/btn_customize_colors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="自定义颜色"
                android:textColor="?attr/appAccent"
                android:textSize="16sp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 字幕设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="字幕设置"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字幕大小"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <Spinner
                android:id="@+id/spinner_subtitle_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字幕语言"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <Spinner
                android:id="@+id/spinner_subtitle_lang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="语音识别语言"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <Spinner
                android:id="@+id/spinner_voice_lang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 更多设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="更多设置"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:id="@+id/tv_disliked_episodes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="不喜欢的节目"
                android:textColor="?attr/appAccent"
                android:textSize="16sp"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider" />
            <TextView
                android:id="@+id/tv_keyword_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="关键词设置"
                android:textColor="?attr/appAccent"
                android:textSize="16sp"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider" />
            <TextView
                android:id="@+id/btn_manage_offline_engine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="离线引擎管理"
                android:textColor="?attr/appAccent"
                android:textSize="16sp"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider" />
            <TextView
                android:id="@+id/tv_cache_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="缓存大小: 计算中..."
                android:textColor="?attr/appTextPrimary"
                android:textSize="14sp"
                android:padding="12dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider" />
            <TextView
                android:id="@+id/btn_clear_cache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="清理缓存"
                android:textColor="?attr/appAccent"
                android:textSize="16sp"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
