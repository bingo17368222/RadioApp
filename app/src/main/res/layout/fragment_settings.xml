<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackground">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 播放设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="播放设置"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI分段模型"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用于区分干货片段和水货片段，将完整字幕划分为有意义的内容段落"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <Spinner
                android:id="@+id/spinner_ai_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字幕生成方案"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="语音识别引擎方案，支持在线和离线识别"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <Spinner
                android:id="@+id/spinner_asr_provider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="自动跳过水分"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="16sp" />
                    <Switch
                        android:id="@+id/switch_auto_skip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自动跳过广告、音乐等非内容片段"
                    android:textColor="?attr/appTextSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="音频预处理"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="16sp" />
                    <Switch
                        android:id="@+id/switch_preprocessing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="缓存完成后自动将音频解码为PCM格式并使用Whisper base模型预先生成完整字幕，加速播放时的字幕显示"
                    android:textColor="?attr/appTextSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="连续播放"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="16sp" />
                    <Switch
                        android:id="@+id/switch_continuous_play"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前节目播放完毕后自动播放下一节目"
                    android:textColor="?attr/appTextSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="自动下载缓存"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="16sp" />
                    <Switch
                        android:id="@+id/switch_auto_download"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="播放节目时自动将音频缓存到本地存储"
                    android:textColor="?attr/appTextSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="启用预缓存"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="16sp" />
                    <Switch
                        android:id="@+id/switch_auto_cache"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="提前缓存即将播放的节目内容"
                    android:textColor="?attr/appTextSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="预缓存数量:"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/et_preload_cache_count"
                        android:layout_width="80dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:text="10"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="14sp"
                        android:inputType="number"
                        android:gravity="center"
                        android:background="@drawable/bg_card"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="个"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="14sp"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="启用音频焦点"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="14sp" />
                    <Switch
                        android:id="@+id/switch_audio_focus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="导航或其他应用播放时暂停播放，之后自动恢复播放"
                    android:textColor="?attr/appTextSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 播放记忆 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="播放记忆"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="自动记忆播放位置"
                    android:textColor="?attr/appTextPrimary"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/switch_save_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="每15秒自动保存播放位置，播放完成后清除，再次进入从此位置继续"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="自动记忆播放节目"
                    android:textColor="?attr/appTextPrimary"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/switch_remember_episode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="记忆最后播放的节目，进入App时提示是否继续播放"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="仅在WiFi下预缓存"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开启后仅在WiFi网络下自动预缓存节目"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <Switch
                android:id="@+id/switch_wifi_precache"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:checked="true" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="通知栏样式"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <Spinner
                android:id="@+id/spinner_notification_style"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:entries="@array/notification_styles" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="快进/快退时间"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <Spinner
                android:id="@+id/spinner_skip_seconds"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:entries="@array/skip_seconds_options" />
        </LinearLayout>

        <!-- [v2.1.2] 拼多多检测间隔设置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="强制音频焦点恢复检测间隔"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <Spinner
                android:id="@+id/spinner_pinduoduo_interval"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:entries="@array/pinduoduo_interval_options" />
        </LinearLayout>

        <!-- [v2.4.9] 字幕滑动暂停自动跳转设置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字幕滑动暂停自动跳转"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手动滑动字幕后，暂停自动跳转的等待时间"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <Spinner
                android:id="@+id/spinner_subtitle_scroll_pause"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:entries="@array/subtitle_scroll_pause_options" />
        </LinearLayout>

        <!-- 界面设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="界面设置"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="界面风格"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择深色、清新、经典、极简或自定义配色方案"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <Spinner
                android:id="@+id/spinner_theme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:id="@+id/btn_customize_colors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="自定义颜色"
                android:textColor="?attr/appAccent"
                android:textSize="16sp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 字幕设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="字幕设置"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字幕大小"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="调节字幕显示的文字大小"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <Spinner
                android:id="@+id/spinner_subtitle_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字幕语言"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字幕显示的语言"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <Spinner
                android:id="@+id/spinner_subtitle_lang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider"
                android:layout_marginVertical="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="语音识别语言"
                android:textColor="?attr/appTextPrimary"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="语音识别时使用的语言"
                android:textColor="?attr/appTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <Spinner
                android:id="@+id/spinner_voice_lang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 更多设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="更多设置"
            android:textColor="?attr/appTextSecondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_disliked_episodes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="不喜欢的节目"
                    android:textColor="?attr/appAccent"
                    android:textSize="16sp"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="管理已标记为不喜欢的节目列表"
                    android:textColor="?attr/appTextSecondary"
                    android:textSize="12sp"
                    android:paddingStart="12dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/appDivider" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_keyword_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="关键词设置"
                    android:textColor="?attr/appAccent"
                    android:textSize="16sp"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />
                <TextView
                    android:layout_width="wrap_content"
