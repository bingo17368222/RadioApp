<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/appTextPrimary" />

        <!-- 主题选择 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="主题风格"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/appTextPrimary"
            android:layout_marginTop="24dp" />

        <RadioGroup
            android:id="@+id/rg_theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rb_theme_fresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清新风格"
                android:textColor="?attr/appTextPrimary" />

            <RadioButton
                android:id="@+id/rb_theme_classic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="经典风格"
                android:textColor="?attr/appTextPrimary" />

            <RadioButton
                android:id="@+id/rb_theme_minimal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="极简风格"
                android:textColor="?attr/appTextPrimary" />

            <RadioButton
                android:id="@+id/rb_theme_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="深色风格"
                android:textColor="?attr/appTextPrimary" />

            <RadioButton
                android:id="@+id/rb_theme_custom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自定义风格"
                android:textColor="?attr/appTextPrimary" />
        </RadioGroup>

        <!-- 自定义颜色设置 -->
        <LinearLayout
            android:id="@+id/custom_color_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自定义颜色"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/appTextPrimary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="主色"
                    android:textColor="?attr/appTextSecondary" />

                <View
                    android:id="@+id/color_primary_preview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/colorPrimary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="背景色"
                    android:textColor="?attr/appTextSecondary" />

                <View
                    android:id="@+id/color_background_preview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/appBackground" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="文字色"
                    android:textColor="?attr/appTextSecondary" />

                <View
                    android:id="@+id/color_text_preview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/appTextPrimary" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_pick_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择颜色"
                android:textColor="?attr/colorOnPrimary"
                android:backgroundTint="?attr/colorPrimary"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 其他设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="播放设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/appTextPrimary"
            android:layout_marginTop="24dp" />

        <CheckBox
            android:id="@+id/cb_auto_play"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自动播放"
            android:textColor="?attr/appTextPrimary"
            android:layout_marginTop="8dp" />

        <CheckBox
            android:id="@+id/cb_show_lyrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="显示歌词"
            android:textColor="?attr/appTextPrimary"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="缓存管理"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/appTextPrimary"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/tv_cache_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="缓存大小: 0 MB"
            android:textSize="14sp"
            android:textColor="?attr/appTextSecondary"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_clear_cache"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="清除缓存"
            android:textColor="?attr/colorOnPrimary"
            android:backgroundTint="?attr/colorPrimary"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_manage_offline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="管理离线引擎"
            android:textColor="?attr/colorOnPrimary"
            android:backgroundTint="?attr/colorPrimary"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关于"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/appTextPrimary"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Radio App v1.2.25"
            android:textSize="14sp"
            android:textColor="?attr/appTextSecondary"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>
