<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background_dark">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

        <!-- 标题 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="离线引擎管理" android:textColor="@color/text_primary" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="16dp" />

        <!-- 引擎1: Whisper -->
        <LinearLayout android:id="@+id/card_whisper" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card" android:padding="16dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Whisper" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
                <TextView android:id="@+id/tv_whisper_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="未下载" android:textColor="@color/warning" android:textSize="14sp" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="大小: 1.5GB | OpenAI 高精度语音识别" android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginTop="4dp" />
            <ProgressBar android:id="@+id/progress_whisper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:visibility="gone" style="?android:attr/progressBarStyleHorizontal" />
            <Button android:id="@+id/btn_whisper_action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="安装" android:textColor="@android:color/white" android:backgroundTint="@color/success" android:layout_marginTop="8dp" android:layout_gravity="end" />
        </LinearLayout>

        <!-- 引擎2: Vosk -->
        <LinearLayout android:id="@+id/card_vosk" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card" android:padding="16dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Vosk" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
                <TextView android:id="@+id/tv_vosk_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="未下载" android:textColor="@color/warning" android:textSize="14sp" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="大小: 40MB | 轻量级离线语音识别" android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginTop="4dp" />
            <ProgressBar android:id="@+id/progress_vosk" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:visibility="gone" style="?android:attr/progressBarStyleHorizontal" />
            <Button android:id="@+id/btn_vosk_action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="安装" android:textColor="@android:color/white" android:backgroundTint="@color/success" android:layout_marginTop="8dp" android:layout_gravity="end" />
        </LinearLayout>

        <!-- 引擎3: PocketSphinx -->
        <LinearLayout android:id="@+id/card_pocketsphinx" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card" android:padding="16dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="PocketSphinx" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
                <TextView android:id="@+id/tv_pocketsphinx_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="未下载" android:textColor="@color/warning" android:textSize="14sp" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="大小: 5MB | 极轻量级关键词识别" android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginTop="4dp" />
            <ProgressBar android:id="@+id/progress_pocketsphinx" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:visibility="gone" style="?android:attr/progressBarStyleHorizontal" />
            <Button android:id="@+id/btn_pocketsphinx_action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="安装" android:textColor="@android:color/white" android:backgroundTint="@color/success" android:layout_marginTop="8dp" android:layout_gravity="end" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
