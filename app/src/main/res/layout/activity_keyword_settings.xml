<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background_dark">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

        <!-- 干货关键词 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="干货关键词" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card" android:padding="16dp" android:layout_marginBottom="16dp">
            <EditText android:id="@+id/et_dry_keywords" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="用逗号分隔，如：新闻,资讯,报道" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:background="@drawable/bg_card" android:padding="12dp" android:textSize="14sp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="匹配逻辑" android:textColor="@color/text_secondary" android:textSize="14sp" />
                <Spinner android:id="@+id/spinner_dry_logic" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
            <Button android:id="@+id/btn_ai_extract_dry" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="AI提取关键词" android:textColor="@android:color/white" android:backgroundTint="@color/accent" android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 水分关键词 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="水分关键词" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card" android:padding="16dp" android:layout_marginBottom="16dp">
            <EditText android:id="@+id/et_water_keywords" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="用逗号分隔，如：广告,音乐,歌曲" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:background="@drawable/bg_card" android:padding="12dp" android:textSize="14sp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="匹配逻辑" android:textColor="@color/text_secondary" android:textSize="14sp" />
                <Spinner android:id="@+id/spinner_water_logic" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
            <Button android:id="@+id/btn_ai_extract_water" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="AI提取关键词" android:textColor="@android:color/white" android:backgroundTint="@color/accent" android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 内容干货关键词 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="内容干货关键词" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card" android:padding="16dp" android:layout_marginBottom="16dp">
            <EditText android:id="@+id/et_content_dry_keywords" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="用逗号分隔" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:background="@drawable/bg_card" android:padding="12dp" android:textSize="14sp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="匹配逻辑" android:textColor="@color/text_secondary" android:textSize="14sp" />
                <Spinner android:id="@+id/spinner_content_dry_logic" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
            <Button android:id="@+id/btn_ai_extract_content_dry" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="AI提取关键词" android:textColor="@android:color/white" android:backgroundTint="@color/accent" android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 内容水分关键词 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="内容水分关键词" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card" android:padding="16dp" android:layout_marginBottom="16dp">
            <EditText android:id="@+id/et_content_water_keywords" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="用逗号分隔" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:background="@drawable/bg_card" android:padding="12dp" android:textSize="14sp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="匹配逻辑" android:textColor="@color/text_secondary" android:textSize="14sp" />
                <Spinner android:id="@+id/spinner_content_water_logic" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
            <Button android:id="@+id/btn_ai_extract_content_water" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="AI提取关键词" android:textColor="@android:color/white" android:backgroundTint="@color/accent" android:layout_marginTop="8dp" />
        </LinearLayout>

        <Button android:id="@+id/btn_save" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="保存设置" android:textColor="@android:color/white" android:backgroundTint="@color/success" android:padding="16dp" android:textSize="16sp" />
    </LinearLayout>
</ScrollView>
